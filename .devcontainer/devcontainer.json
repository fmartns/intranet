{
  "name": "Intranet Dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "django",
  "workspaceFolder": "/workspace",
  "remoteUser": "appuser",
  "overrideCommand": true,
  "updateRemoteUserUID": true,
  "forwardPorts": [8000, 5432, 6379, 8080],
  "portsAttributes": {
    "8000": {
      "label": "Django",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "ADK (future)",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.flake8",
        "ms-python.black-formatter",
        "ms-python.isort",
        "batisteo.vscode-django",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.analysis.extraPaths": ["/workspace/django"],
        "python.envFile": "/workspace/.env",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["django"],
        "terminal.integrated.env.linux": {
          "DJANGO_SETTINGS_MODULE": "core.settings.development",
          "PYTHONPATH": "/workspace/django"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "black-formatter.args": ["--line-length", "120"],
        "isort.args": ["--profile", "black", "--line-length", "120"],
        "flake8.args": ["--config", "/workspace/.flake8"],
        "flake8.cwd": "/workspace/django",
        "files.associations": {
          "*.html": "django-html"
        },
        "emmet.includeLanguages": {
          "django-html": "html"
        }
      }
    }
  },
  "postCreateCommand": "poetry install --no-interaction --no-ansi",
  "postStartCommand": "git config --global --add safe.directory /workspace || true"
}
