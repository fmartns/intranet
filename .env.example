DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_SETTINGS_MODULE=core.settings.development

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
