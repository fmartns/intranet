[flake8]
max-line-length = 120
max-complexity = 12
extend-ignore = E203, W503
exclude =
    .git,
    .venv,
    venv,
    __pycache__,
    node_modules,
    migrations,
    .devcontainer,
    .pytest_cache,
    .mypy_cache,
    .ruff_cache,
    build,
    dist,
    *.egg-info
per-file-ignores =
    django/core/settings/__init__.py:F401
